<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>New Build | AutoBuilder</title>

  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header class="site-header">
    <nav class="nav">
      <a href="/" class="logo">AutoBuilder</a>

      <div class="nav-links">
        <a href="/builds">Builds</a>
        <a href="/builds/new">New Build</a>
      </div>
    </nav>
  </header>

  <main class="container">
    <p class="eyebrow">New project</p>
    <h1>Create a car build</h1>

    <form action="/builds" method="POST" class="form-card">
      <div class="form-group">
        <label for="build_name">Build name</label>
        <input
          type="text"
          id="build_name"
          name="build_name"
          placeholder="Example: Weekend Supra build"
          required
        />
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="make">Make</label>
          <input
            type="text"
            id="make"
            name="make"
            placeholder="Toyota"
            required
          />
        </div>

        <div class="form-group">
          <label for="model">Model</label>
          <input
            type="text"
            id="model"
            name="model"
            placeholder="Supra"
            required
          />
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="year">Year</label>
          <input
            type="number"
            id="year"
            name="year"
            placeholder="2020"
            min="1950"
            max="2035"
          />
        </div>

        <div class="form-group">
          <label for="budget">Budget</label>
          <input
            type="number"
            id="budget"
            name="budget"
            placeholder="15000"
            min="0"
            step="0.01"
          />
        </div>
      </div>

      <div class="form-group">
        <label for="goal">Build goal</label>
        <input
          type="text"
          id="goal"
          name="goal"
          placeholder="Street build, track build, clean OEM+ build..."
        />
      </div>

      <div class="form-group">
        <label for="notes">Notes</label>
        <textarea
          id="notes"
          name="notes"
          rows="5"
          placeholder="Write your build ideas, target power, style, future plans..."
        ></textarea>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn primary">Save build</button>
        <a href="/builds" class="btn secondary">Cancel</a>
      </div>
    </form>
  </main>
</body>
</html>