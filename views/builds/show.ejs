<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title><%= build.build_name %> | AutoBuilder</title>

  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header class="site-header">
    <nav class="nav">
      <a href="/" class="logo">AutoBuilder</a>

      <div class="nav-links">
        <a href="/builds">Builds</a>
        <a href="/builds/new">New Build</a>
      </div>
    </nav>
  </header>

  <main class="container">
    <a href="/builds" class="back-link">← Back to builds</a>

    <section class="hero">
      <p class="eyebrow">Build details</p>

      <h1><%= build.build_name %></h1>

      <p class="subtitle">
        <%= build.year || "Year not set" %>
        <%= build.make %>
        <%= build.model %>
      </p>
    </section>

    <section class="detail-grid">
      <div class="feature-card">
        <h3>Build goal</h3>
        <p><%= build.goal || "No goal added yet." %></p>
      </div>

      <div class="feature-card">
        <h3>Budget</h3>
        <p>$<%= build.budget || 0 %></p>
      </div>

      <div class="feature-card">
        <h3>Created</h3>
        <p><%= build.created_at %></p>
      </div>
    </section>

    <section class="feature-card notes-card">
      <h3>Notes</h3>
      <p><%= build.notes || "No notes added yet." %></p>
    </section>

    <section class="modifications-section">
      <div class="page-header">
        <div>
          <p class="eyebrow">Build parts</p>
          <h2>Modifications</h2>
        </div>

        <a
          href="/builds/<%= build.id %>/modifications/new"
          class="btn primary"
        >
          Add modification
        </a>
      </div>

      <div class="build-stats">
        <div class="feature-card">
          <h3>Parts</h3>
          <p class="stat-value">
            <%= modifications.length %>
          </p>
        </div>

        <div class="feature-card">
          <h3>Installed</h3>
          <p class="stat-value">
            <%= installedCount %>
          </p>
        </div>

        <div class="feature-card">
          <h3>Parts cost</h3>
          <p class="stat-value">
            $<%= totalModificationCost.toFixed(2) %>
          </p>
        </div>
      </div>

      <% if (modifications.length === 0) { %>

        <div class="feature-card">
          <h3>No modifications yet</h3>

          <p>
            Add your first planned, purchased, or installed part.
          </p>
        </div>

      <% } else { %>

        <div class="modification-list">

          <% modifications.forEach((modification) => { %>

            <article class="modification-card">

              <div class="modification-header">
                <div>
                  <p class="category">
                    <%= modification.category %>
                  </p>

                  <h3>
                    <%= modification.part_name %>
                  </h3>

                  <% if (modification.brand) { %>
                    <p>
                      <%= modification.brand %>
                    </p>
                  <% } %>
                </div>

                <span
                  class="status-badge status-<%= modification.status.toLowerCase() %>"
                >
                  <%= modification.status %>
                </span>
              </div>

              <p class="modification-cost">
                $<%= Number(modification.cost || 0).toFixed(2) %>
              </p>

              <% if (modification.notes) { %>
                <p>
                  <%= modification.notes %>
                </p>
              <% } %>

              <div class="modification-actions">
                <a
                  href="/builds/<%= build.id %>/modifications/<%= modification.id %>/edit"
                  class="btn secondary"
                >
                  Edit
                </a>

                <form
                  action="/builds/<%= build.id %>/modifications/<%= modification.id %>?_method=DELETE"
                  method="POST"
                  onsubmit="return confirm('Are you sure you want to delete this modification?');"
                >
                  <button type="submit" class="btn danger">
                    Delete
                  </button>
                </form>
              </div>

            </article>

          <% }) %>

        </div>

      <% } %>
    </section>

    <section class="build-actions">
      <a
        href="/builds/<%= build.id %>/edit"
        class="btn secondary"
      >
        Edit build
      </a>

      <form
        action="/builds/<%= build.id %>?_method=DELETE"
        method="POST"
        onsubmit="return confirm('Are you sure you want to delete this build?');"
      >
        <button type="submit" class="btn danger">
          Delete build
        </button>
      </form>
    </section>
  </main>

</body>
</html>
