<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title><%= build.build_name %> | AutoBuilder</title>

  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header class="site-header">
    <nav class="nav">
      <a href="/" class="logo">AutoBuilder</a>

      <div class="nav-links">
        <a href="/builds">Builds</a>
        <a href="/builds/new">New Build</a>
      </div>
    </nav>
  </header>

  <main class="container">
    <a href="/builds" class="back-link">← Back to builds</a>

    <section class="hero">
      <p class="eyebrow">Build details</p>

      <h1><%= build.build_name %></h1>

      <p class="subtitle">
        <%= build.year || "Year not set" %>
        <%= build.make %>
        <%= build.model %>
      </p>
    </section>

    <section class="detail-grid">
      <div class="feature-card">
        <h3>Build goal</h3>
        <p><%= build.goal || "No goal added yet." %></p>
      </div>

      <div class="feature-card">
        <h3>Budget</h3>
        <p>$<%= build.budget || 0 %></p>
      </div>

      <div class="feature-card">
        <h3>Created</h3>
        <p><%= build.created_at %></p>
      </div>
    </section>

    <section class="feature-card notes-card">
      <h3>Notes</h3>
      <p><%= build.notes || "No notes added yet." %></p>
    </section>
  </main>
</body>
</html>