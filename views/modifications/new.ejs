<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Add Modification | BuildSpec Garage</title>

  <link rel="stylesheet" href="/styles.css" />
</head>

<body>
  <header class="site-header">
    <nav class="nav">
      <a href="/" class="logo">BuildSpec Garage</a>

      <div class="nav-links">
        <a href="/builds">Builds</a>
        <a href="/builds/new">New Build</a>
      </div>
    </nav>
  </header>

  <main class="container">
    <a
      href="/builds/<%= build.id %>"
      class="back-link"
    >
      ← Back to build
    </a>

    <p class="eyebrow">New modification</p>

    <h1>Add a part</h1>

    <p class="subtitle">
      Adding to:
      <strong>
        <%= build.year || "" %>
        <%= build.make %>
        <%= build.model %>
      </strong>
    </p>

    <form
      action="/builds/<%= build.id %>/modifications"
      method="POST"
      class="form-card"
    >
      <div class="form-group">
        <label for="part_name">Part name</label>

        <input
          type="text"
          id="part_name"
          name="part_name"
          placeholder="AWE Touring Exhaust"
          required
        />
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="brand">Brand</label>

          <input
            type="text"
            id="brand"
            name="brand"
            placeholder="AWE"
          />
        </div>

        <div class="form-group">
          <label for="cost">Cost</label>

          <input
            type="number"
            id="cost"
            name="cost"
            min="0"
            step="0.01"
            placeholder="2100"
          />
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="category">Category</label>

          <select
            id="category"
            name="category"
            required
          >
            <option value="">Select category</option>
            <option value="Engine">Engine</option>
            <option value="Exhaust">Exhaust</option>
            <option value="Suspension">Suspension</option>
            <option value="Wheels & Tires">Wheels & Tires</option>
            <option value="Brakes">Brakes</option>
            <option value="Exterior">Exterior</option>
            <option value="Interior">Interior</option>
            <option value="Electronics">Electronics</option>
            <option value="Other">Other</option>
          </select>
        </div>

        <div class="form-group">
          <label for="status">Status</label>

          <select
            id="status"
            name="status"
            required
          >
            <option value="Planned">Planned</option>
            <option value="Purchased">Purchased</option>
            <option value="Installed">Installed</option>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label for="notes">Notes</label>

        <textarea
          id="notes"
          name="notes"
          rows="4"
          placeholder="Fitment details, future plans, installation notes..."
        ></textarea>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn primary">
          Add modification
        </button>

        <a
          href="/builds/<%= build.id %>"
          class="btn secondary"
        >
          Cancel
        </a>
      </div>
    </form>
  </main>
</body>
</html>