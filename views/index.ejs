<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BuildSpec Garage</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header class="site-header">
    <nav class="nav">
      <a href="/" class="logo">BuildSpec Garage</a>
    </nav>
  </header>

  <main class="container">
    <section class="hero">
      <p class="eyebrow">Dream car build planner</p>

      <h1>Plan your sports car build from idea to finished setup.</h1>

      <p class="subtitle">
        Track car builds, planned modifications, parts, costs, and installation progress
        in one clean dashboard.
      </p>

      <div class="hero-actions">
        <a href="#" class="btn primary">Create first build</a>
        <a href="#" class="btn secondary">View builds</a>
      </div>
    </section>

    <section class="feature-grid">
      <div class="feature-card">
        <h3>Create builds</h3>
        <p>Add cars you want to build, customize, or research.</p>
      </div>

      <div class="feature-card">
        <h3>Track modifications</h3>
        <p>Organize parts by category like engine, exhaust, suspension, wheels, and brakes.</p>
      </div>

      <div class="feature-card">
        <h3>Monitor cost</h3>
        <p>Track planned, purchased, and installed parts with total build cost.</p>
      </div>
    </section>
  </main>
</body>
</html>